# Admin panel password (required, 20+ characters)
ADMIN_PASSWORD=

# JWT secret for auth tokens (optional, auto-generated if empty)
JWT_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# OpenRouter API for text generation
OPENROUTER_API_KEY=

# LLM model (default: openai/gpt-4.1-mini)
LLM_MODEL=openai/gpt-4.1-mini

# PaddleOCR API URL (default for local dev, set to http://paddleocr:8866 in Docker)
PADDLEOCR_URL=http://localhost:8866

# Font path for text rendering (optional, system default if empty)
FONT_PATH=
